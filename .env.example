# Resend (https://resend.com): API sends contact form to your inbox without opening the visitor's mail app.
RESEND_API_KEY=re_xxxxxxxx
# Verified sender, e.g. "Italomarco <onboarding@resend.dev>" until you add your domain in Resend.
RESEND_FROM="Italomarco <onboarding@resend.dev>"

# Optional: override recipient (defaults to lib/contact-email.ts)
# CONTACT_TO_EMAIL=
